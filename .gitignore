# Python
.venv/
__pycache__/
*.pyc
*.egg-info/

# Secrets / local env
.env

# Hidden folders (anything starting with '.') — never push
# Covers runtime/tool dirs like .omx/, .jeo/, .pocket/, .pytest_cache/, .survey/, etc.
.*/

# Exceptions: keep these tracked
!.gitignore
# .survey holds committed research output — keep it versioned
!.survey/
